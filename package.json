{
  "name": "docweaver",
  "version": "0.0.0",
  "description": "",
  "homepage": "https://github.com/miguelkjesus/docweaver#readme",
  "bugs": {
    "url": "https://github.com/miguelkjesus/docweaver/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miguelkjesus/docweaver.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "bin": {
    "docweaver": "./dist/bin/docweaver.js"
  },
  "scripts": {
    "prepack": "npm run lint:check && npm run build:clean",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "build:watch": "tsc -p tsconfig.build.json && (concurrently \"tsc -w -p tsconfig.build.json\" \"tsc-alias -w -p tsconfig.build.json --resolve-full-paths\")",
    "build:clean": "rm -rf ./dist && npm run build",
    "type:check": "tsc --noEmit",
    "build:check": "tsc && publint --strict",
    "lint": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest"
  },
  "imports": {
    "#package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "default": "./dist/exports/config.js",
      "types": "./dist/exports/config.d.ts"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ],
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/js-yaml": "^4.0.9",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^25.5.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "memfs": "^4.56.11",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@npmcli/package-json": "^7.0.5",
    "@types/npmcli__package-json": "^4.0.4",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "find-up": "^8.0.0",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
